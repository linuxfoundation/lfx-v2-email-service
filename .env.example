#
# Local development environment variables.
# Copy this file to .env and adjust values for your setup.
#
#   cp .env.example .env
#
# .env is git-ignored and never committed.

# NATS server URL
NATS_URL=nats://localhost:4222

# HTTP health probe port
PORT=8080

# Set to false to use the no-op sender (logs requests, no SMTP connection required)
EMAIL_ENABLED=true

# SMTP server — Mailpit running in the local cluster (UI at http://localhost:8025)
SMTP_HOST=lfx-platform-mailpit-smtp.lfx.svc.cluster.local
SMTP_PORT=25
SMTP_FROM=noreply@lfx.linuxfoundation.org

# SMTP credentials — not required when using Mailpit
SMTP_USERNAME=
SMTP_PASSWORD=

# Logging
LOG_LEVEL=debug
LOG_ADD_SOURCE=true
